# =================================================================
# BrewOps Coffee Shop SaaS — Environment Configuration
# =================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to git!
# =================================================================

# -----------------------------------------------------------------
# DATABASE (Required)
# -----------------------------------------------------------------
# For local development with Docker:
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/brewops?schema=public"
#
# For Vercel Postgres:
#   DATABASE_URL="postgres://username:password@host:5432/database?sslmode=require"
#
# For Supabase (recommended for Vercel):
#   1. Supabase Dashboard → Project Settings → Database → Connection string
#   2. Copy "Transaction pooler" (port 6543) → DATABASE_URL
#   3. Copy "Direct connection" (port 5432) → DIRECT_URL
#
# DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
#
# For Neon:
#   DATABASE_URL="postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/brewops?sslmode=require"
#
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/brewops?schema=public"

# -----------------------------------------------------------------
# AUTHENTICATION (Required)
# -----------------------------------------------------------------
# Generate a secure random secret (min 32 chars):
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
JWT_SECRET="CHANGE_ME_TO_A_SECURE_RANDOM_STRING_MIN_32_CHARS"

# -----------------------------------------------------------------
# APPLICATION (Optional)
# -----------------------------------------------------------------
PORT=3000

# -----------------------------------------------------------------
# PAYMENT GATEWAY (Optional — for real payment processing)
# -----------------------------------------------------------------
# Stripe (International):
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_PUBLISHABLE_KEY="pk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
#
# Midtrans (Indonesia):
# MIDTRANS_SERVER_KEY="Mid-server-..."
# MIDTRANS_CLIENT_KEY="Mid-client-..."
# MIDTRANS_IS_PRODUCTION=false
#
# Xendit (Southeast Asia):
# XENDIT_SECRET_KEY="xnd_..."

# -----------------------------------------------------------------
# SEO & ANALYTICS (Optional)
# -----------------------------------------------------------------
# GOOGLE_VERIFICATION_CODE="your-google-verification-code"
# GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"
# NEXT_PUBLIC_SITE_URL="https://your-domain.com"
